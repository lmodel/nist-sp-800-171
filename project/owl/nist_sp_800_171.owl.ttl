        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_171:label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_171:_class ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_171:_class ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_171:label ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_171:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_171:label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_171:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_171:CatalogElementClassValue ;
            owl:onProperty nist_sp_800_171:_class ],
        nist_sp_800_171:CatalogElement ;
    skos:definition "A catalog element with required id, title, and optional class/label" ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-171> .

