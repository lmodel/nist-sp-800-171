    rdfs:label "ResponsibleParty" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_171:party_uuids ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_171:role_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_171:role_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty nist_sp_800_171:party_uuids ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_171:role_id ] ;
    skos:definition "Assignment of parties to a role" ;
    skos:exactMatch linkml:Any ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-171> .

