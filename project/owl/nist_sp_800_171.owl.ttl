<https://w3id.org/lmodel/nist-sp-800-171.owl.ttl> a owl:Ontology ;
    rdfs:label "NIST-SP-800-171" ;
    dcterms:source <https://doi.org/10.6028/NIST.SP.800-171r3> ;
    pav:version "3.0.0" ;
    skos:definition "Electronic (LinkML) Version of Protecting Controlled Unclassified Information in Nonfederal Systems and Organizations" .

nist_sp_800_171:SP800171Document a owl:Class ;
    rdfs:label "SP800171Document" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom nist_sp_800_171:CatalogBody ;
            owl:onProperty nist_sp_800_171:catalog ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty nist_sp_800_171:catalog ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty nist_sp_800_171:catalog ] ;
    skos:definition "Root wrapper for SP 800-171 catalog content" ;
    skos:exactMatch linkml:Any ;
    skos:inScheme <https://w3id.org/lmodel/nist-sp-800-171> .

nist_sp_800_171:remarks a owl:DatatypeProperty ;
    rdfs:label "remarks" ;
    skos:definition "Supplemental remarks" ;
