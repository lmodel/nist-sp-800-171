            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:addr_lines ],
        [ sh:class nist_sp_800_171:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path nist_sp_800_171:links ],
