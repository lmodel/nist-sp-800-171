@prefix linkml: <https://w3id.org/linkml/> .
@prefix nist_sp_800_171: <https://w3id.org/lmodel/nist-sp-800-171/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

nist_sp_800_171:CatalogElement a sh:NodeShape ;
    rdfs:comment "Base class for catalog elements with id, props, links, and parts" ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type nist_sp_800_171:name nist_sp_800_171:controls nist_sp_800_171:title nist_sp_800_171:_class nist_sp_800_171:usage nist_sp_800_171:guidelines nist_sp_800_171:label nist_sp_800_171:prose nist_sp_800_171:params ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:id ],
        [ sh:class nist_sp_800_171:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path nist_sp_800_171:props ],
        [ sh:class nist_sp_800_171:Part ;
            sh:description "Nested parts providing prose, statements, guidance, assessment objectives and methods" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path nist_sp_800_171:parts ],
        [ sh:class nist_sp_800_171:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nist_sp_800_171:links ] ;
    sh:targetClass nist_sp_800_171:CatalogElement .

nist_sp_800_171:IdentifiedElement a sh:NodeShape ;
    rdfs:comment "A catalog element with required id, title, and optional class/label" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type nist_sp_800_171:controls nist_sp_800_171:usage nist_sp_800_171:guidelines nist_sp_800_171:params ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_sp_800_171:id ],
        [ sh:class nist_sp_800_171:Part ;
            sh:description "Nested parts providing prose, statements, guidance, assessment objectives and methods" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path nist_sp_800_171:parts ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:title ],
        [ sh:class nist_sp_800_171:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path nist_sp_800_171:links ],
        [ sh:class nist_sp_800_171:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path nist_sp_800_171:props ],
        [ sh:description "Classification of a catalog element (e.g. family, requirement, security_requirement)" ;
            sh:in ( "family" "requirement" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path nist_sp_800_171:_class ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_171:label ] ;
    sh:targetClass nist_sp_800_171:IdentifiedElement .

nist_sp_800_171:Control a sh:NodeShape ;
    rdfs:comment "A security requirement" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_171:title ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_sp_800_171:label ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path nist_sp_800_171:id ],
        [ sh:class nist_sp_800_171:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path nist_sp_800_171:props ],
        [ sh:class nist_sp_800_171:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path nist_sp_800_171:links ],
        [ sh:description "Classification of a catalog element (e.g. family, requirement, security_requirement)" ;
            sh:in ( "family" "requirement" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path nist_sp_800_171:_class ],
        [ sh:class nist_sp_800_171:Parameter ;
            sh:description "List of organization-defined parameters for a requirement" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nist_sp_800_171:params ],
        [ sh:class nist_sp_800_171:Part ;
            sh:description "Nested parts providing prose, statements, guidance, assessment objectives and methods" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path nist_sp_800_171:parts ] ;
    sh:targetClass nist_sp_800_171:Control .

nist_sp_800_171:ControlGroup a sh:NodeShape ;
    rdfs:comment "A family group of security requirements" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nist_sp_800_171:Control ;
            sh:description "List of security requirements in a family group" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nist_sp_800_171:controls ],
        [ sh:description "Classification of a catalog element (e.g. family, requirement, security_requirement)" ;
            sh:in ( "family" "requirement" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path nist_sp_800_171:_class ],
        [ sh:class nist_sp_800_171:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path nist_sp_800_171:props ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_sp_800_171:label ],
        [ sh:class nist_sp_800_171:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path nist_sp_800_171:links ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path nist_sp_800_171:id ],
        [ sh:class nist_sp_800_171:Part ;
            sh:description "Nested parts providing prose, statements, guidance, assessment objectives and methods" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path nist_sp_800_171:parts ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_171:title ] ;
    sh:targetClass nist_sp_800_171:ControlGroup .

nist_sp_800_171:Guideline a sh:NodeShape ;
    rdfs:comment "Additional prose guidance associated with a parameter" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Free-text prose content" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:prose ] ;
    sh:targetClass nist_sp_800_171:Guideline .

nist_sp_800_171:Parameter a sh:NodeShape ;
    rdfs:comment "An organization-defined parameter for a security requirement" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Human-readable label" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path nist_sp_800_171:label ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_171:title ],
        [ sh:description "Classification of a catalog element (e.g. family, requirement, security_requirement)" ;
            sh:in ( "family" "requirement" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path nist_sp_800_171:_class ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path nist_sp_800_171:id ],
        [ sh:class nist_sp_800_171:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path nist_sp_800_171:props ],
        [ sh:class nist_sp_800_171:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path nist_sp_800_171:links ],
        [ sh:class nist_sp_800_171:Part ;
            sh:description "Nested parts providing prose, statements, guidance, assessment objectives and methods" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path nist_sp_800_171:parts ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description of an organization-defined parameter's expected value" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:usage ],
        [ sh:class nist_sp_800_171:Guideline ;
            sh:description "List of guidelines for a parameter" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path nist_sp_800_171:guidelines ] ;
    sh:targetClass nist_sp_800_171:Parameter .

nist_sp_800_171:Role a sh:NodeShape ;
    rdfs:comment "Role definition" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:id ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_171:title ] ;
    sh:targetClass nist_sp_800_171:Role .

nist_sp_800_171:Part a sh:NodeShape ;
    rdfs:comment "Structured narrative part containing prose and optional nested parts. Used for statements, guidance, assessment-objectives, and assessment-methods." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nist_sp_800_171:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path nist_sp_800_171:props ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for an element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_sp_800_171:id ],
        [ sh:class nist_sp_800_171:Part ;
            sh:description "Nested parts providing prose, statements, guidance, assessment objectives and methods" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path nist_sp_800_171:parts ],
        [ sh:description "Classification of a catalog element (e.g. family, requirement, security_requirement)" ;
            sh:in ( "security_requirement" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path nist_sp_800_171:_class ],
        [ sh:class nist_sp_800_171:Link ;
            sh:description "List of links and relationships" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path nist_sp_800_171:links ],
        [ sh:datatype xsd:string ;
            sh:description "Name of a property, part, or party" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:name ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text prose content" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_171:prose ] ;
    sh:targetClass nist_sp_800_171:Part .

nist_sp_800_171:Link a sh:NodeShape ;
    rdfs:comment "Relationship link" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Relationship type for a link" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_171:rel ],
        [ sh:datatype xsd:string ;
            sh:description "Link or resource reference" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:href ] ;
    sh:targetClass nist_sp_800_171:Link .

nist_sp_800_171:Property a sh:NodeShape ;
    rdfs:comment "A name-value property with optional namespace" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Property value" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_171:value ],
        [ sh:datatype xsd:string ;
            sh:description "Name of a property, part, or party" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:name ],
        [ sh:datatype xsd:string ;
            sh:description "Classification of a catalog element (e.g. family, requirement, security_requirement)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_sp_800_171:_class ],
        [ sh:datatype xsd:string ;
            sh:description "Namespace URI for a property" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_171:ns ] ;
    sh:targetClass nist_sp_800_171:Property .

linkml:Any a sh:NodeShape ;
    rdfs:comment "Assignment of parties to a role",
        "Citation wrapper",
        "Main catalog object",
        "OSCAL back-matter section",
        "OSCAL metadata section",
        "Party definition",
        "Postal address",
        "Reference link for a resource",
        "Referenced resource",
        "Root wrapper for SP 800-171 catalog content" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ),
        ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Citation text" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:text ],
        [ sh:class linkml:Any ;
            sh:description "Root catalog payload" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nist_sp_800_171:catalog ],
        [ sh:class nist_sp_800_171:Property ;
            sh:description "List of properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path nist_sp_800_171:props ],
        [ sh:datatype xsd:string ;
            sh:description "Assigned role identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:role_id ],
        [ sh:class linkml:Any ;
            sh:description "Back-matter references and resources" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path nist_sp_800_171:back_matter ],
        [ sh:datatype xsd:string ;
            sh:description "City name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_171:city ],
        [ sh:class linkml:Any ;
            sh:description "Citation details for a resource" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path nist_sp_800_171:citation ],
        [ sh:datatype xsd:string ;
            sh:description "Party type" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_171:type ],
        [ sh:datatype xsd:string ;
            sh:description "UUID for catalog, metadata, or resource element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:uuid ],
        [ sh:datatype xsd:string ;
            sh:description "Link or resource reference" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:href ],
        [ sh:class nist_sp_800_171:ControlGroup ;
            sh:description "List of requirement family groups in the catalog" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path nist_sp_800_171:groups ],
        [ sh:class linkml:Any ;
            sh:description "Postal addresses" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path nist_sp_800_171:addresses ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:title ],
        [ sh:datatype xsd:string ;
            sh:description "Publication timestamp" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_171:published ],
        [ sh:datatype xsd:string ;
            sh:description "UUID for catalog, metadata, or resource element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:uuid ],
        [ sh:datatype xsd:string ;
            sh:description "Short display name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_sp_800_171:short_name ],
        [ sh:datatype xsd:string ;
            sh:description "Party email addresses" ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path nist_sp_800_171:email_addresses ],
        [ sh:datatype xsd:string ;
            sh:description "Media type for a resource link" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_171:media_type ],
        [ sh:datatype xsd:string ;
            sh:description "Name of a property, part, or party" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_171:name ],
        [ sh:class linkml:Any ;
            sh:description "Responsible party assignments" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path nist_sp_800_171:responsible_parties ],
        [ sh:datatype xsd:string ;
            sh:description "Version identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_sp_800_171:version ],
        [ sh:datatype xsd:string ;
            sh:description "Last modification timestamp" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_171:last_modified ],
        [ sh:class linkml:Any ;
            sh:description "Parties used in metadata" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path nist_sp_800_171:parties ],
        [ sh:datatype xsd:string ;
            sh:description "Referenced party UUIDs" ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_171:party_uuids ],
        [ sh:class linkml:Any ;
            sh:description "Resource links" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path nist_sp_800_171:rlinks ],
        [ sh:datatype xsd:string ;
            sh:description "UUID for catalog, metadata, or resource element" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path nist_sp_800_171:uuid ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable title" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path nist_sp_800_171:title ],
        [ sh:datatype xsd:string ;
            sh:description "OSCAL version identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path nist_sp_800_171:oscal_version ],
        [ sh:datatype xsd:string ;
            sh:description "Resource description" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_171:description ],
        [ sh:datatype xsd:string ;
            sh:description "Postal code" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path nist_sp_800_171:postal_code ],
        [ sh:datatype xsd:string ;
            sh:description "State or region" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path nist_sp_800_171:state ],
