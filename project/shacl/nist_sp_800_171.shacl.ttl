            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path nist_sp_800_171:metadata ],
        [ sh:class linkml:Any ;
            sh:description "Back-matter resources" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path nist_sp_800_171:resources ] ;
